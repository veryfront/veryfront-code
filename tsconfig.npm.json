{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationOnly": true,
    "emitDeclarationOnly": true,
    "outDir": "./npm/dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "paths": {
      "@veryfront": ["./src/index.ts"],
      "@veryfront/*": ["./src/*"],
      "react": ["./node_modules/@types/react"],
      "react-dom": ["./node_modules/@types/react-dom"]
    },
    "types": ["node"],
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/index.ts",
    "src/agent/index.ts",
    "src/agent/react/index.ts",
    "src/agent/middleware/index.ts",
    "src/tool/index.ts",
    "src/workflow/index.ts",
    "src/workflow/react/index.ts",
    "src/prompt/index.ts",
    "src/resource/index.ts",
    "src/mcp/index.ts",
    "src/provider/index.ts",
    "src/react/primitives/index.ts",
    "src/react/components/ai/index.ts",
    "src/core/config/index.ts",
    "src/core/oauth/index.ts",
    "src/data/index.ts",
    "src/react/components/index.ts",
    "src/exports/context.ts",
    "src/exports/head.ts",
    "src/exports/router.ts",
    "src/exports/fonts.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "npm",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*_test.ts",
    "**/*_test.tsx"
  ]
}
