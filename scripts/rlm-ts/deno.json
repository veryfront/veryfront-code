{
  "name": "@veryfront/rlm",
  "version": "0.1.0",
  "exports": "./src/index.ts",
  "tasks": {
    "check": "deno check src/index.ts",
    "test": "deno test --allow-env --allow-net",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "example": "deno run --allow-env --allow-net examples/basic.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve"
  }
}
