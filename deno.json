{
  "name": "veryfront",
  "version": "0.0.75",
  "nodeModulesDir": "auto",
  "exclude": [
    "npm/",
    "dist/",
    "coverage/",
    "scripts/",
    "examples/",
    "data/",
    "src/cli/templates/files/",
    "src/cli/templates/integrations/"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli/main.ts",
    "./server": "./src/server/index.ts",
    "./middleware": "./src/middleware/index.ts",
    "./components": "./src/react/components/index.ts",
    "./data": "./src/data/index.ts",
    "./config": "./src/core/config/index.ts",
    "./platform": "./src/platform/index.ts",
    "./ai": "./src/ai/index.ts",
    "./ai/client": "./src/ai/client.ts",
    "./ai/react": "./src/ai/react/index.ts",
    "./ai/primitives": "./src/ai/react/primitives/index.ts",
    "./ai/components": "./src/ai/react/components/index.ts",
    "./ai/production": "./src/ai/production/index.ts",
    "./ai/dev": "./src/ai/dev/index.ts",
    "./ai/workflow": "./src/ai/workflow/index.ts",
    "./ai/workflow/react": "./src/ai/workflow/react/index.ts",
    "./oauth": "./src/core/oauth/index.ts",
    "./oauth/providers": "./src/core/oauth/providers/index.ts",
    "./oauth/handlers": "./src/core/oauth/handlers/index.ts",
    "./oauth/token-store": "./src/core/oauth/token-store/index.ts",
    "./head": "./src/exports/head.ts",
    "./router": "./src/exports/router.ts",
    "./context": "./src/exports/context.ts",
    "./fonts": "./src/exports/fonts.ts"
  },
  "imports": {
    "veryfront/head": "./src/exports/head.ts",
    "veryfront/router": "./src/exports/router.ts",
    "veryfront/context": "./src/exports/context.ts",
    "veryfront/fonts": "./src/exports/fonts.ts",
    "@veryfront": "./src/index.ts",
    "@veryfront/": "./src/",
    "@veryfront/ai": "./src/ai/index.ts",
    "@veryfront/ai/": "./src/ai/",
    "@veryfront/platform": "./src/platform/index.ts",
    "@veryfront/platform/": "./src/platform/",
    "@veryfront/types": "./src/core/types/index.ts",
    "@veryfront/types/": "./src/core/types/",
    "@veryfront/utils": "./src/core/utils/index.ts",
    "@veryfront/utils/": "./src/core/utils/",
    "@veryfront/middleware": "./src/middleware/index.ts",
    "@veryfront/middleware/": "./src/middleware/",
    "@veryfront/errors": "./src/core/errors/index.ts",
    "@veryfront/errors/": "./src/core/errors/",
    "@veryfront/config": "./src/core/config/index.ts",
    "@veryfront/config/": "./src/core/config/",
    "@veryfront/observability": "./src/observability/index.ts",
    "@veryfront/observability/": "./src/observability/",
    "@veryfront/routing": "./src/routing/index.ts",
    "@veryfront/routing/": "./src/routing/",
    "@veryfront/transforms": "./src/build/transforms/index.ts",
    "@veryfront/transforms/": "./src/build/transforms/",
    "@veryfront/data": "./src/data/index.ts",
    "@veryfront/data/": "./src/data/",
    "@veryfront/security": "./src/security/index.ts",
    "@veryfront/security/": "./src/security/",
    "@veryfront/components": "./src/react/components/index.ts",
    "@veryfront/react": "./src/react/index.ts",
    "@veryfront/react/": "./src/react/",
    "@veryfront/html": "./src/html/index.ts",
    "@veryfront/html/": "./src/html/",
    "@veryfront/rendering": "./src/rendering/index.ts",
    "@veryfront/rendering/": "./src/rendering/",
    "@veryfront/build": "./src/build/index.ts",
    "@veryfront/build/": "./src/build/",
    "@veryfront/server": "./src/server/index.ts",
    "@veryfront/server/": "./src/server/",
    "@veryfront/modules": "./src/module-system/index.ts",
    "@veryfront/modules/": "./src/module-system/",
    "@veryfront/compat/console": "./src/platform/compat/console/index.ts",
    "@veryfront/compat/": "./src/platform/compat/",
    "@veryfront/oauth": "./src/core/oauth/index.ts",
    "@veryfront/oauth/": "./src/core/oauth/",
    "std/": "https://deno.land/std@0.220.0/",
    "@std/path": "https://deno.land/std@0.220.0/path/mod.ts",
    "@std/testing/bdd.ts": "https://deno.land/std@0.220.0/testing/bdd.ts",
    "@std/expect": "https://deno.land/std@0.220.0/expect/mod.ts",
    "csstype": "https://esm.sh/csstype@3.2.3",
    "@types/react": "https://esm.sh/@types/react@18.3.27?deps=csstype@3.2.3",
    "@types/react-dom": "https://esm.sh/@types/react-dom@18.3.7?deps=csstype@3.2.3",
    "react": "https://esm.sh/react@18.3.1?target=es2022",
    "react-dom": "https://esm.sh/react-dom@18.3.1?target=es2022&external=react",
    "react-dom/server": "https://esm.sh/react-dom@18.3.1/server?target=es2022&external=react",
    "react-dom/client": "https://esm.sh/react-dom@18.3.1/client?target=es2022&external=react",
    "react/jsx-runtime": "https://esm.sh/react@18.3.1/jsx-runtime?target=es2022",
    "react/jsx-dev-runtime": "https://esm.sh/react@18.3.1/jsx-dev-runtime?target=es2022",
    "@mdx-js/mdx": "npm:@mdx-js/mdx@3.0.0",
    "@mdx-js/react": "npm:@mdx-js/react@3.0.0",
    "unist-util-visit": "npm:unist-util-visit@5.0.0",
    "mdast-util-to-string": "npm:mdast-util-to-string@4.0.0",
    "github-slugger": "npm:github-slugger@2.0.0",
    "remark-gfm": "npm:remark-gfm@4.0.1",
    "remark-frontmatter": "npm:remark-frontmatter@5.0.0",
    "rehype-highlight": "npm:rehype-highlight@7.0.2",
    "rehype-slug": "npm:rehype-slug@6.0.0",
    "esbuild": "npm:esbuild@0.20.2",
    "esbuild/mod.js": "npm:esbuild@0.20.2",
    "es-module-lexer": "npm:es-module-lexer@1.5.0",
    "zod": "npm:zod@3.25.76",
    "mime-types": "npm:mime-types@2.1.35",
    "mdast": "npm:@types/mdast@4.0.3",
    "hast": "npm:@types/hast@3.0.3",
    "unist": "npm:@types/unist@3.0.2",
    "unified": "npm:unified@11.0.5",
    "ai": "npm:ai@5.0.76",
    "ai/react": "npm:@ai-sdk/react@2.0.1",
    "@ai-sdk/react": "npm:@ai-sdk/react@2.0.1",
    "@ai-sdk/openai": "https://esm.sh/@ai-sdk/openai@2.0.1",
    "@ai-sdk/anthropic": "https://esm.sh/@ai-sdk/anthropic@2.0.1",
    "unocss": "https://esm.sh/unocss@0.59.0",
    "@unocss/core": "https://esm.sh/@unocss/core@0.59.0",
    "@unocss/preset-wind": "https://esm.sh/@unocss/preset-wind@0.59.0",
    "next-themes": "https://esm.sh/next-themes@0.4?target=es2022&external=react,react-dom",
    "@tanstack/react-query": "https://esm.sh/@tanstack/react-query@5?target=es2022&external=react,react-dom",
    "@tanstack/query-core": "https://esm.sh/@tanstack/query-core@5?target=es2022",
    "framer-motion": "https://esm.sh/framer-motion@11?target=es2022&external=react,react-dom",
    "react-hook-form": "https://esm.sh/react-hook-form@7?target=es2022&external=react,react-dom",
    "redis": "npm:redis",
    "pg": "npm:pg",
    "@opentelemetry/api": "npm:@opentelemetry/api@1",
    "@opentelemetry/core": "npm:@opentelemetry/core@1",
    "@opentelemetry/context-async-hooks": "npm:@opentelemetry/context-async-hooks@1",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@1",
    "@opentelemetry/exporter-trace-otlp-http": "npm:@opentelemetry/exporter-trace-otlp-http@0.57",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@1",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@1",
    "@babel/parser": "npm:@babel/parser@7.26.3",
    "@babel/traverse": "npm:@babel/traverse@7.26.3",
    "@babel/generator": "npm:@babel/generator@7.26.3",
    "@babel/types": "npm:@babel/types@7.26.3"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "types": ["npm:@types/react@18"],
    "lib": [
      "deno.window",
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ]
  },
  "tasks": {
    "setup": "deno run --allow-all scripts/setup.ts",
    "dev": "deno run --allow-all --no-lock --unstable-net --unstable-worker-options src/cli/main.ts dev",
    "proxy": "deno run --allow-all scripts/dev-proxy.ts",
    "build": "deno compile --allow-all --output ../../bin/veryfront src/cli/main.ts",
    "build:npm": "deno run -A scripts/build-npm.ts",
    "release": "deno run -A scripts/release.ts",
    "test": "VF_DISABLE_LRU_INTERVAL=1 NODE_ENV=production LOG_FORMAT=text deno test --parallel --allow-all --unstable-worker-options --unstable-net",
    "test:unit": "VF_DISABLE_LRU_INTERVAL=1 NODE_ENV=production LOG_FORMAT=text deno test --parallel --allow-all --v8-flags=--max-old-space-size=8192 --ignore=tests,src/ai/workflow/__tests__ --unstable-worker-options --unstable-net",
    "test:integration": "VF_DISABLE_LRU_INTERVAL=1 NODE_ENV=production LOG_FORMAT=text deno test --parallel --allow-all tests --unstable-worker-options --unstable-net",
    "test:record": "VCR=record deno test --allow-all src/cli/commands/*.integration.test.ts",
    "test:coverage": "rm -rf coverage && VF_DISABLE_LRU_INTERVAL=1 NODE_ENV=production LOG_FORMAT=text deno test --parallel --fail-fast --allow-all --coverage=coverage --unstable-worker-options --unstable-net || exit 1",
    "test:coverage:unit": "rm -rf coverage && VF_DISABLE_LRU_INTERVAL=1 NODE_ENV=production LOG_FORMAT=text deno test --parallel --fail-fast --allow-all --coverage=coverage --ignore=tests --unstable-worker-options --unstable-net || exit 1",
    "test:coverage:integration": "rm -rf coverage && VF_DISABLE_LRU_INTERVAL=1 NODE_ENV=production LOG_FORMAT=text deno test --parallel --fail-fast --allow-all --coverage=coverage tests --unstable-worker-options --unstable-net || exit 1",
    "coverage:report": "deno coverage coverage --include=src/ --exclude=tests --exclude=src/**/*_test.ts --exclude=src/**/*_test.tsx --exclude=src/**/*.test.ts --exclude=src/**/*.test.tsx --lcov > coverage/lcov.info && deno run --allow-read scripts/check-coverage.ts 80",
    "coverage:html": "deno coverage coverage --include=src/ --exclude=tests --exclude=src/**/*_test.ts --exclude=src/**/*_test.tsx --exclude=src/**/*.test.ts --exclude=src/**/*.test.tsx --html",
    "lint": "DENO_NO_PACKAGE_JSON=1 deno lint src/",
    "fmt": "deno fmt src/",
    "fmt:check": "deno fmt --check src/",
    "typecheck": "deno check src/index.ts src/cli/main.ts src/server/index.ts src/routing/api/index.ts src/rendering/index.ts src/platform/index.ts src/platform/adapters/index.ts src/build/index.ts src/build/production-build/index.ts src/build/transforms/index.ts src/core/config/index.ts src/core/utils/index.ts src/data/index.ts src/security/index.ts src/middleware/index.ts src/server/handlers/dev/index.ts src/server/handlers/request/api/index.ts src/rendering/cache/index.ts src/rendering/cache/stores/index.ts src/rendering/rsc/actions/index.ts src/html/index.ts src/module-system/index.ts",
    "verify": "deno fmt --check src/ && DENO_NO_PACKAGE_JSON=1 deno lint src/ && deno task typecheck && deno task test",
    "verify:quick": "deno fmt --check src/ && DENO_NO_PACKAGE_JSON=1 deno lint src/ && deno task typecheck",
    "docs:check-links": "deno run -A scripts/check-doc-links.ts",
    "lint:ban-console": "deno run --allow-read scripts/ban-console.ts",
    "lint:ban-deep-imports": "deno run --allow-read scripts/ban-deep-imports.ts",
    "lint:ban-internal-root-imports": "deno run --allow-read scripts/ban-internal-root-imports.ts",
    "lint:check-awaits": "deno run --allow-read scripts/check-unawaited-promises.ts",
    "lint:platform": "deno run --allow-read scripts/lint-platform-agnostic.ts",
    "test:smoke": "deno run --allow-all src/platform/compat/smoke-test.ts",
    "test:cross-runtime": "deno run --allow-all src/platform/compat/cross-runtime.test.ts",
    "check:circular": "deno run -A jsr:@cunarist/deno-circular-deps src/index.ts"
  },
  "lint": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "dist/",
      "coverage/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "ban-untagged-todo"
      ],
      "exclude": [
        "no-explicit-any",
        "no-process-global",
        "no-console"
      ]
    }
  },
  "fmt": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "dist/",
      "coverage/"
    ],
    "options": {
      "useTabs": false,
      "lineWidth": 100,
      "indentWidth": 2,
      "semiColons": true,
      "singleQuote": false,
      "proseWrap": "preserve"
    }
  }
}
