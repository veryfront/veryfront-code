{
  "name": "veryfront",
  "version": "0.0.75",
  "description": "Zero-config React meta-framework for building agentic AI applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "veryfront": "./bin/veryfront.js"
  },
