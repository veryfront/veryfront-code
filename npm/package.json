    "@mdx-js/react": "^3.0.0",
    "mime-types": "^2.1.35",
    "unified": "^11.0.0",
    "remark-gfm": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "github-slugger": "^2.0.0",
    "picocolors": "^1.1.0",
