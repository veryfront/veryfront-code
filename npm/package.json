  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "framework",
    "ai",
    "agents",
    "mcp",
    "llm",
    "anthropic",
    "openai",
    "ssr",
    "rsc",
    "server-components",
    "typescript"
  ],
  "license": "MIT",
  "author": "Veryfront",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veryfront/veryfront.git"
  },
  "bugs": {
    "url": "https://github.com/veryfront/veryfront/issues"
  },
  "homepage": "https://veryfront.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
