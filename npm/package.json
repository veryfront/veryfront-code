    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "github-slugger": "^2.0.0",
    "picocolors": "^1.1.0",
    "mri": "^1.2.0",
    "yaml": "^2.3.0",
    "js-yaml": "^4.1.0",
    "gray-matter": "^4.0.3",
    "ws": "^8.18.0",
