{
  "name": "deploy-safely",
  "version": "1.0.0",
  "description": "Build, test, deploy, and verify — with automatic rollback on failure",
  "requires": {
    "cli": ["build", "test", "deploy"],
    "mcp": ["vf_get_errors"]
  },
  "inputs": {
    "environment": {
      "type": "string",
      "default": "production",
      "description": "Target environment"
    },
    "branch": { "type": "string", "default": "main", "description": "Branch to deploy" }
  }
}
