{
  "name": "blob",
  "description": "S3-compatible blob storage for file uploads (MinIO, AWS S3, etc.)",
  "envVars": [
    {
      "name": "S3_ENDPOINT",
      "description": "S3-compatible endpoint URL",
      "required": true,
      "sensitive": false,
      "placeholder": "http://localhost:9000"
    },
    {
      "name": "S3_ACCESS_KEY",
      "description": "S3 access key ID",
      "required": true,
      "sensitive": true,
      "placeholder": "minioadmin"
    },
    {
      "name": "S3_SECRET_KEY",
      "description": "S3 secret access key",
      "required": true,
      "sensitive": true,
      "placeholder": "minioadmin"
    },
    {
      "name": "S3_BUCKET",
      "description": "S3 bucket name",
      "required": true,
      "sensitive": false,
      "placeholder": "uploads"
    }
  ],
  "tips": [
    "Start MinIO: docker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ':9001'",
    "Upload files via /api/upload endpoint",
    "UI available at /upload",
    "Compatible with AWS S3, MinIO, Cloudflare R2, etc."
  ]
}
