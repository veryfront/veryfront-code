      "endpoint": {
        "type": "graphql",
        "method": "POST",
        "url": "https://api.linear.app/graphql",
        "query": "query($first: Int) { users(first: $first) { nodes { id name displayName email active avatarUrl } } }",
        "params": {
          "first": {
