import { ConsentProvider } from "@/shared/context/ConsentProvider"
import { UserProvider } from "@/shared/context/UserProvider"
import { cn } from "@/shared/utils/utils"
import { ScrollDepthTracker } from "@/shared/ui/ScrollDepthTracker"
import { usePageContext } from "@/lib/usePageContext"
import { RouterEvents } from "@/shared/ui/RouterEvents"
import { useRouter } from "@/lib/Router"
import { Head } from "@/lib/Head"
import React from "react"
import { ThemeProvider } from "https://esm.sh/next-themes"

export function getPageTitle(value) {
  if (!value) {
    return "Build & Ship All in One Place - Veryfront"
  }

  let title = value

  if (!title?.endsWith?.("- Veryfront")) {
    title = title + " - Veryfront"
  }

  return title
}

export function HeadAndMeta() {
  const router = useRouter()
  const pageContext = usePageContext()
  const context = pageContext.frontmatter?.context ?? {}
  const pageTitle = getPageTitle(context.meta?.title)

  return (
    <>
      <Head>
        <meta
          httpEquiv="Content-Security-Policy"
          content="script-src 'self' blob: https://cdn.veryfront.com https://esm.sh https://snap.licdn.com https://static.ads-twitter.com https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net 'unsafe-inline' 'unsafe-eval'; worker-src 'self' blob:; img-src 'self' blob: https://images.veryfront.com https://res.cloudinary.com https://cdn.veryfront.com https://www.facebook.com https://t.co https://analytics.twitter.com https://www.linkedin.com https://px.ads.linkedin.com https://px4.ads.linkedin.com https://www.google-analytics.com https://www.google.com https://www.google.se https://www.googletagmanager.com https://lh3.googleusercontent.com; object-src 'none';"
        />
        <html lang="en" />
        <link
          href="https://vjs.zencdn.net/8.16.1/video-js.css"
          rel="stylesheet"
        />
        <body className="antialiased bg-background text-foreground min-h-[100dvh]" />
        <title>{pageTitle}</title>
        <meta name="description" content={context.meta?.description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preconnect" href="https://cdn.veryfront.com" />
        <link
          rel="shortcut icon"
          type="image/svg+xml"
          href="https://cdn.veryfront.com/images/veryfront-figuremark-28.svg"
        />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={context.meta?.title} />
        <meta property="og:description" content={context.meta?.description} />
        <meta
          property="og:image"
          content="https://cdn.veryfront.com/5b74466b-ad05-4594-82f6-8ed08ad1c37c/images/veryfront-og-image.png"
        />
        <meta name="twitter:card" content="summary_large_image" />
        <meta property="twitter:domain" content="veryfront.com" />
        <meta name="twitter:title" content={context.meta?.title} />
        <meta name="twitter:description" content={context.meta?.description} />
        <meta
          name="twitter:image"
          content="https://cdn.veryfront.com/5b74466b-ad05-4594-82f6-8ed08ad1c37c/images/veryfront-og-image.png"
        />
        <link
          href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          rel="stylesheet"
        />
        {context.GOOGLE_TAG_MANAGER_ID && (
          <script
            defer
            dangerouslySetInnerHTML={{
              __html: `
              // create dataLayer
              window.dataLayer = window.dataLayer || [];
              function gtag() {
                  dataLayer.push(arguments);
              }
              // set „denied" as default for both ad and analytics storage,
              gtag("consent", "default", {
                  ad_storage: "denied",
                  analytics_storage: "denied",
                  wait_for_update: 2000 // milliseconds to wait for update
              });
              // Enable ads data redaction by default [optional]
              gtag("set", "ads_data_redaction", true);
              // Google Tag Manager
              (function(w, d, s, l, i) {
                  w[l] = w[l] || [];
                  w[l].push({
                      'gtm.start': new Date().getTime(),
                      event: 'gtm.js'
                  });
                  var f = d.getElementsByTagName(s)[0],
                      j = d.createElement(s),
                      dl = l != 'dataLayer' ? '&l=' + l : '';
                  j.async = true;
                  j.src =
                      'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
                  f.parentNode.insertBefore(j, f);
              })(window, document, 'script', 'dataLayer', '${context.GOOGLE_TAG_MANAGER_ID}');
            `,
            }}
          />
        )}
      </Head>

      <ScrollDepthTracker
        onDepthReached={({ scrollDepth }) => {
          if (!window?.gtag) {
            console.info("gtag not found, scroll not sent.")
            return
          }
          gtag("event", "scroll", {
            // GA Universal Format
            eventCategory: "Scroll Depth",
            eventAction: "Percentage",
            eventLabel: scrollDepth?.toString(),
            nonInteraction: true,
          })
        }}
      />
      <RouterEvents
        onRouteChangeEnd={(context) => {
          if (!window?.gtag) {
            console.info("gtag not found, page view not sent.")
            return
          }
          gtag("event", "page_view")
        }}
      />
    </>
  )
}

<ThemeProvider>
  <HeadAndMeta />
  <ConsentProvider
    onSubmit={(privacySettings) => {
      if (!window.gtag) {
        return
      }
      gtag("consent", "update", {
        ad_storage: privacySettings.advertising ? "granted" : "denied",
        analytics_storage: privacySettings.functional ? "granted" : "denied",
      })
      window.dataLayer?.push({
        event: "consent_status",
        "Google Tag Manager": privacySettings["Google Tag Manager"],
        "Google Analytics": privacySettings["Google Analytics"],
        "Google Analytics Advertising":
          privacySettings["Google Analytics Advertising"],
        "Facebook Pixel": privacySettings["Facebook Pixel"],
        "LinkedIn Insight Tag": privacySettings["LinkedIn Insight Tag"],
        "Twitter Advertising": privacySettings["Twitter Advertising"],
      })
      if (privacySettings["Google Analytics"] === true) {
        gtag("event", "page_view")
      }
    }}
  >
    <UserProvider>{props.children}</UserProvider>
  </ConsentProvider>
</ThemeProvider>
