# Veryfront Server - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# Proxy API Configuration
VERYFRONT_PROXY_API_BASE_URL=https://api.veryfront.com

# Single Project Mode (deno task production)
VERYFRONT_API_TOKEN=
VERYFRONT_PROJECT_SLUG=

# Headless Mode (deno task start --headless) / Split Mode (deno task start-split)
# OAuth credentials for proxy to fetch project tokens
VERYFRONT_PROXY_API_CLIENT_ID=
VERYFRONT_PROXY_API_CLIENT_SECRET=
REDIS_URL=

# Proxy Mode (deployed pods)
# Set PROXY_MODE=1 only for hosted/deployed runtimes.
# Requires NODE_ENV=production and a valid signing key.
# PROXY_MODE=1
# NODE_ENV=production
# CHANNEL_DISPATCH_SIGNING_PUBLIC_KEY=

# Binary compilation
# Set to 1 to always rebuild binary, even if source unchanged
VERYFRONT_BINARY_FRESH=1

# OpenTelemetry (optional - host-owned in shared/proxy runtime)
# In shared/proxy runtime, set these only on the platform process. Project env
# overlays cannot choose the shared runtime collector endpoint or credentials.
# In dedicated runtime, these may be project/deployment env vars because the
# project has its own process boundary.
# VERYFRONT_OTEL=1
# OTEL_TRACES_ENABLED=true
# OTEL_METRICS_ENABLED=true
# OTEL_SERVICE_NAME=veryfront-server
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp-endpoint
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ...

# Logging (debug | info | warn | error)
LOG_LEVEL=info
