# Veryfront Renderer - Local Development
# ======================================
# Copy this file to .env and fill in your credentials.
# Get OAuth credentials from 1Password: "Veryfront OAuth Credentials"

# OAuth Credentials (for proxy mode: deno task proxy)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_PREVIEW_CLIENT_ID=
OAUTH_PREVIEW_CLIENT_SECRET=

# API Configuration
VERYFRONT_API_BASE_URL=https://api.veryfront.com

# Direct Mode (deno task dev) - uncomment to use
# VERYFRONT_API_TOKEN=your_token_here
# VERYFRONT_PROJECT_SLUG=your-project

# Logging (debug | info | warn | error)
LOG_LEVEL=info
