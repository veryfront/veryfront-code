# Veryfront Renderer - Local Development
# ======================================
# Copy this file to .env and fill in your credentials.

# Single Project Mode (deno task renderer)
VERYFRONT_API_TOKEN=your_token_here
VERYFRONT_PROJECT_SLUG=your-project

# API Configuration
VERYFRONT_API_BASE_URL=https://api.veryfront.com

# Multi-project Mode (deno task start) - Veryfront staff only
# Get OAuth credentials from 1Password: VERYFRONT_CI / "Veryfront Renderer Proxy OAuth"
# These credentials authenticate with the API's veryfront-renderer-proxy service account
# API_CLIENT_ID_VERYFRONT_RENDERER_PROXY=
# API_CLIENT_SECRET_VERYFRONT_RENDERER_PROXY=

# Redis (proxy token cache - optional for local dev, uses memory if not set)
# REDIS_URL=redis://localhost:6379

# Logging (debug | info | warn | error)
LOG_LEVEL=info
