# Proxy Mode Local Development Configuration
# Copy to proxy.env: cp proxy.env.example proxy.env
#
# Get OAuth credentials from 1Password: "Veryfront OAuth Credentials"

# OAuth credentials for production domains (*.veryfront.com)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# OAuth credentials for preview domains (*.preview.veryfront.com)
OAUTH_PREVIEW_CLIENT_ID=
OAUTH_PREVIEW_CLIENT_SECRET=

# Proxy configuration
PORT=8080
RENDERER_URL=http://localhost:3001
CACHE_TYPE=memory
VERYFRONT_API_BASE_URL=https://api.veryfront.com

# Logging
LOG_LEVEL=debug
