# =============================================================================
# Veryfront Renderer - Local Development Configuration
# =============================================================================
# This file configures both direct mode (deno task dev) and proxy mode
# (deno task proxy). Copy to .env.local and fill in your credentials.
#
# Get OAuth credentials from 1Password: "Veryfront OAuth Credentials"
# =============================================================================

# -----------------------------------------------------------------------------
# Mode Selection
# -----------------------------------------------------------------------------
# PROXY_MODE=0  → Direct mode (single project, token from env)
# PROXY_MODE=1  → Proxy mode (multi-project, OAuth per-request)
PROXY_MODE=1

# -----------------------------------------------------------------------------
# OAuth Credentials (Proxy Mode)
# -----------------------------------------------------------------------------
# Production domains (*.veryfront.com)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Preview domains (*.preview.veryfront.com)
OAUTH_PREVIEW_CLIENT_ID=
OAUTH_PREVIEW_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Direct Mode Settings (when PROXY_MODE=0)
# -----------------------------------------------------------------------------
# VERYFRONT_API_TOKEN=vf_...
# VERYFRONT_PROJECT_SLUG=my-project

# -----------------------------------------------------------------------------
# API & URLs
# -----------------------------------------------------------------------------
VERYFRONT_API_BASE_URL=https://api.veryfront.com
RENDERER_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
PORT=3001
PRODUCTION_MODE=0
CACHE_TYPE=memory

# -----------------------------------------------------------------------------
# Logging & Debug
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
ENABLE_MEMORY_MONITORING=true

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
SSR_MAX_CONCURRENT_TRANSFORMS=1
