{
  "version": 1,
  "phase": "local-first",
  "comparison_frameworks": [
    "veryfront",
    "nextjs"
  ],
  "metrics": {
    "browser_primary": [
      "ttfb_ms",
      "fcp_ms",
      "lcp_ms",
      "inp_ms",
      "cls",
      "tbt_ms"
    ],
    "server_primary": [
      "latency_p50_ms",
      "latency_p95_ms",
      "latency_p99_ms",
      "requests_per_second",
      "error_rate",
      "memory_mb",
      "cpu_percent",
      "response_bytes",
      "ssr_render_ms",
      "rsc_stream_ms"
    ]
  },
  "fairness_rules": {
    "build_mode": "production",
    "same_host_required": true,
    "same_browser_required": true,
    "same_sample_policy_required": true,
    "raw_artifacts_required": true
  },
  "scenarios": [
    {
      "id": "static_route",
      "kind": "browser_and_server",
      "path": "/bench/static",
      "description": "A light route with minimal server and client work.",
      "primary_metrics": [
        "ttfb_ms",
        "fcp_ms",
        "lcp_ms",
        "response_bytes",
        "latency_p95_ms"
      ],
      "requirements": {
        "async_data": false,
        "hydration": false,
        "streaming": false,
        "api_shape": null
      }
    },
    {
      "id": "ssr_data_route",
      "kind": "browser_and_server",
      "path": "/bench/ssr-data",
      "description": "A server-rendered route that performs async data loading before response.",
      "primary_metrics": [
        "ttfb_ms",
        "lcp_ms",
        "latency_p95_ms",
        "latency_p99_ms",
        "ssr_render_ms"
      ],
      "requirements": {
        "async_data": true,
        "hydration": false,
        "streaming": false,
        "api_shape": null
      }
    },
    {
      "id": "interactive_hydrated_route",
      "kind": "browser_and_server",
      "path": "/bench/interactive",
      "description": "A route that renders useful HTML and hydrates interactive client behavior.",
      "primary_metrics": [
        "ttfb_ms",
        "lcp_ms",
        "inp_ms",
        "tbt_ms",
        "cls",
        "response_bytes"
      ],
      "requirements": {
        "async_data": false,
        "hydration": true,
        "streaming": false,
        "api_shape": null
      }
    },
    {
      "id": "api_route",
      "kind": "server_only",
      "path": "/api/bench/status",
      "description": "A representative JSON API endpoint with matched response shape.",
      "primary_metrics": [
        "latency_p50_ms",
        "latency_p95_ms",
        "latency_p99_ms",
        "requests_per_second",
        "error_rate",
        "response_bytes"
      ],
      "requirements": {
        "async_data": true,
        "hydration": false,
        "streaming": false,
        "api_shape": {
          "ok": true,
          "source": "framework-name",
          "items": 10
        }
      }
    }
  ]
}
